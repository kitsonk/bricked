# BrickLink API credentials
# Generate these at: https://www.bricklink.com/v3/api.page
#
# Consumer Key and Secret identify your application (from the API key registration).
# Token and Token Secret are your personal access credentials for your store account.

BRICKLINK_CONSUMER_KEY=
BRICKLINK_CONSUMER_SECRET=
BRICKLINK_TOKEN=
BRICKLINK_TOKEN_SECRET=

# Sender Address (optional)
# JSON object used as the return address on printed shipping labels.
# If omitted, labels will be printed without a return address.
#
# SENDER_ADDRESS={"recipientName":"Your Name","addressLine1":"123 Example St","addressLine2":"","addressLine3":"","suburb":"Suburb","state":"State","postcode":"0000"}

# Basic auth (optional — leave unset to disable auth entirely)
# Gates the whole app behind a single username/password. Use a long random
# SESSION_SECRET (e.g. `openssl rand -hex 32`) so cookie signatures can't be
# forged. Rotating SESSION_SECRET invalidates all existing sessions.
#
# APP_USERNAME=admin
# APP_PASSWORD=change-me
# SESSION_SECRET=

# Bot banlist (optional — sensible defaults are used if unset)
# Bans an IP for BANLIST_TTL_MS once it has accumulated BANLIST_THRESHOLD
# unauthenticated requests (401s from /api/* and 302s to /login) within
# BANLIST_WINDOW_MS. Banned IPs receive 403 + Retry-After. Set
# TRUST_FORWARDED_FOR=1 only if the app is behind a reverse proxy that
# populates X-Forwarded-For and you trust the header.
#
# BANLIST_THRESHOLD=20
# BANLIST_WINDOW_MS=3600000
# BANLIST_TTL_MS=86400000
# BANLIST_CACHE_MAX=10000
# TRUST_FORWARDED_FOR=0
